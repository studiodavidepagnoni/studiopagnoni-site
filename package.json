{
  "name": "studio-pagnoni-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.cjs",
    "sync:static": "node scripts/sync-static.cjs",
    "process:hero-videos": "node scripts/process-hero-videos.cjs",
    "gen:favicon": "node scripts/gen-favicon.cjs",
    "predev": "node scripts/sync-static.cjs",
    "prebuild": "node scripts/sync-static.cjs",
    "dev": "cross-env NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:fresh": "npm run clean && cross-env NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:turbopack": "next dev --turbopack",
    "build": "next build",
    "build:static": "cross-env STATIC_EXPORT=1 next build",
    "rebuild": "npm run clean && npm run build",
    "prestart": "node scripts/check-next-build.cjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
